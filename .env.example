# AI Provider Configuration
# Set USE_OPENROUTER=true to use OpenRouter (free models available)
# Set USE_OPENROUTER=false to use Anthropic Claude
USE_OPENROUTER=true

# OpenRouter API Configuration (Free tier available)
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic API Configuration (Alternative to OpenRouter)
# Only needed if USE_OPENROUTER=false
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server Configuration
PORT=3000

# Logging Configuration
NODE_ENV=development
LOG_LEVEL=info
