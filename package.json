{
  "name": "venture-lens-ai-agent",
  "version": "1.0.0",
  "description": "AI-powered venture capital analysis platform",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/api/index.ts",
    "scrape": "bun src/scrapers/scrape.ts",
    "batch-scrape": "bun src/cli/batch-scrape.ts",
    "analyze": "bun src/ai/analyzer.ts",
    "start": "bun src/api/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "keywords": [
    "venture-capital",
    "ai",
    "analysis",
    "scraper"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/openai": "^3.0.52",
    "@hono/node-server": "^1.14.0",
    "ai": "^6.0.152",
    "hono": "^4.6.16",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.49.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.1.15",
    "@types/node": "^22.10.5",
    "lefthook": "^1.9.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
